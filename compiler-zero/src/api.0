}

fun compiler_self_host_world_write_literal_start_at(source_ptr: usize, source_len: usize, wanted: usize) -> usize {
  let mut i: usize = 0
  let mut found: usize = 0
  while i + 5 <= source_len {
    if std.mem.peekByte(source_ptr + i) == 119_u8 {
      if std.mem.peekByte(source_ptr + i + 1) == 114_u8 {
        if std.mem.peekByte(source_ptr + i + 2) == 105_u8 {
          if std.mem.peekByte(source_ptr + i + 3) == 116_u8 {
            if std.mem.peekByte(source_ptr + i + 4) == 101_u8 {
              let mut j = i + 5
              while j < source_len {
                if std.mem.peekByte(source_ptr + j) == 34_u8 {
                  if found == wanted { return j + 1 }
                  found = found + 1
                  j = source_len
                }
                j = j + 1
              }
            }
          }
        }
      }
    }
    i = i + 1
  }
  return source_len
}

fun compiler_self_host_string_literal_decoded_len(source_ptr: usize, source_len: usize, literal_start: usize) -> usize {
  let mut raw = literal_start
  let mut decoded: usize = 0
  while raw < source_len {
    let code = std.mem.peekByte(source_ptr + raw)
    if code == 34_u8 { return decoded }
    if code == 92_u8 {
      raw = raw + 1
      if raw >= source_len { return 0 }
    }
    decoded = decoded + 1
    raw = raw + 1
  }
  return 0
}

fun compiler_self_host_string_literal_decoded_byte(source_ptr: usize, literal_start: usize, decoded_index: usize) -> u8 {
  let mut raw = literal_start
  let mut decoded: usize = 0
  while true {
    let code = std.mem.peekByte(source_ptr + raw)
    if code == 34_u8 { return 0_u8 }
    if code == 92_u8 {
      raw = raw + 1
      let escaped = std.mem.peekByte(source_ptr + raw)
      if decoded == decoded_index {
        if escaped == 110_u8 { return 10_u8 }
        return escaped
      }
    } else {
      if decoded == decoded_index { return code }
    }
    decoded = decoded + 1
    raw = raw + 1
  }
  return 0_u8
}

fun compiler_self_host_write_source_stdout_wasm_bytes(source_ptr: usize, out_ptr: usize, literal_start: usize, payload_len: usize) -> Bool {
  let total = payload_len + 141
  let mut payload_len_byte: u8 = 0_u8
  let mut len_index: usize = 0
  while len_index < payload_len {
    payload_len_byte = payload_len_byte + 1_u8
    len_index = len_index + 1
  }
  let data_len_byte = payload_len_byte + 1_u8
  let section_size_byte = payload_len_byte + 8_u8
  let mut i: usize = 0
  while i < total {
    let mut byte: u8 = 0_u8
    if i < 131 { byte = compiler_self_host_stdout_prefix_byte(i, payload_len_byte) }
    if i == 131 { byte = 11_u8 }
    if i == 132 { byte = section_size_byte }
    if i == 133 { byte = 1_u8 }
    if i == 135 { byte = 65_u8 }
    if i == 136 { byte = 128_u8 }
    if i == 137 { byte = 8_u8 }
    if i == 138 { byte = 11_u8 }
    if i == 139 { byte = data_len_byte }
    if i >= 140 {
      let data_index = i - 140
      if data_index < payload_len {
        byte = compiler_self_host_string_literal_decoded_byte(source_ptr, literal_start, data_index)
      }
    }
    let ok = std.mem.pokeByte(out_ptr + i, byte)
    if ok {
      i = i + 1
    } else {
      return false
    }
  }
  return true
}

