fun compiler_self_host_source_has_literal(source_ptr: usize, source_len: usize, literal_id: u32) -> Bool {
  let literal_len = compiler_self_host_literal_len(literal_id)
  if literal_len == 0 { return false }
  if source_len < literal_len { return false }
  let mut start: usize = 0
  while start + literal_len <= source_len {
    let mut i: usize = 0
    let mut matched = true
    while i < literal_len {
      if std.mem.peekByte(source_ptr + start + i) == compiler_self_host_literal_byte(literal_id, i) {
        i = i + 1
      } else {
        matched = false
        i = literal_len
      }
    }
    if matched { return true }
    start = start + 1
  }
  return false
}

fun compiler_self_host_stdout_prefix_byte(index: usize, payload_len: u8) -> u8 {
