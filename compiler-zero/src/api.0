export c fun compiler_self_host_gap_mask() -> u32 {
  return 0_u32
}

export c fun compiler_self_host_gap_diag_code(gap_bit: u32) -> i32 {
  if gap_bit == 512_u32 { return 7003 }
  if gap_bit == 1024_u32 { return 7004 }
  if gap_bit == 2048_u32 { return 7005 }
  if gap_bit == 4096_u32 { return 7006 }
  return 0
}

export c fun compiler_self_host_stage_plan(stage: u32, supported_mask: u32, required_mask: u32, generated_c_bytes: u32, c_bridge_required: u32) -> u32 {
  if required_mask == 0_u32 { return 0_u32 }
  if generated_c_bytes > 0_u32 { return 7001_u32 }
  if c_bridge_required > 0_u32 { return 7002_u32 }
  if supported_mask == required_mask {
    if stage >= 3_u32 { return 3300_u32 }
    if stage == 2_u32 { return 3200_u32 }
  }
  if stage == 1_u32 { return 3101_u32 }
  if stage == 2_u32 { return 3201_u32 }
  if stage == 3_u32 { return 3301_u32 }
  return 3001_u32
}

