  }
  let mut literal_start = compiler_self_host_world_write_literal_start(source_ptr, source_len)
  if compiler_self_host_source_has_literal(source_ptr, source_len, 3_u32) {
    let branch_literal_start = compiler_self_host_world_write_literal_start_at(source_ptr, source_len, 1)
    if branch_literal_start < source_len {
      literal_start = branch_literal_start
    }
  }
  if compiler_self_host_source_has_literal(source_ptr, source_len, 2_u32) {
    let mut branch_index: usize = 1
    if compiler_self_host_source_has_literal(source_ptr, source_len, 5_u32) {
      branch_index = 0
    }
    let branch_literal_start = compiler_self_host_world_write_literal_start_at(source_ptr, source_len, branch_index)
    if branch_literal_start < source_len {
      literal_start = branch_literal_start
    }
  }
  if literal_start < source_len {
    let payload_len = compiler_self_host_string_literal_decoded_len(source_ptr, source_len, literal_start)
    if payload_len > 0 {
      if payload_len <= 119 {
        let total = payload_len + 141
        if out_len >= total {
          if out_ptr < memory_len {
            if out_len <= memory_len - out_ptr {
              if compiler_self_host_write_source_stdout_wasm_bytes(source_ptr, out_ptr, literal_start, payload_len) {
                let mut total32: u32 = 141_u32
                let mut total_index: usize = 0
                while total_index < payload_len {
                  total32 = total32 + 1_u32
                  total_index = total_index + 1
                }
                return total32
              }
            }
          }
        }
      }
    }
  }
  return 0_u32
}

fun compiler_self_host_world_write_literal_start(source_ptr: usize, source_len: usize) -> usize {
