export c fun compiler_self_host_minimal_wasm_hash(out_ptr: usize, out_len: usize, memory_len: usize) -> u32 {
  if out_len < 8 { return 0_u32 }
  if out_ptr >= memory_len { return 0_u32 }
  if out_len > memory_len - out_ptr { return 0_u32 }
  if std.mem.peekByte(out_ptr) != 0_u8 { return 0_u32 }
  if std.mem.peekByte(out_ptr + 1) != 97_u8 { return 0_u32 }
  if std.mem.peekByte(out_ptr + 2) != 115_u8 { return 0_u32 }
  if std.mem.peekByte(out_ptr + 3) != 109_u8 { return 0_u32 }
  if std.mem.peekByte(out_ptr + 4) != 1_u8 { return 0_u32 }
  if std.mem.peekByte(out_ptr + 5) != 0_u8 { return 0_u32 }
  if std.mem.peekByte(out_ptr + 6) != 0_u8 { return 0_u32 }
  if std.mem.peekByte(out_ptr + 7) != 0_u8 { return 0_u32 }
  return 1836278016_u32
}

