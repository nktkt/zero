                    let start_offset = offset
                    let start_line = line
                    let start_column = column
                    i = i + 1
                    offset = offset + 1_u32
                    column = column + 1_u32
                    let pushed_symbol = std.mem.vecPush(&mut tokens, 8_u8)
                    if pushed_symbol {
                        token_offsets[token_index] = start_offset
                        token_lengths[token_index] = 1_u32
                        token_lines[token_index] = start_line
                        token_columns[token_index] = start_column
                        handled = true
                    } else {
                        return 0
                    }
                }
            }
            if handled {
            } else {
                if is_digit_ascii(source[i]) {
                    let token_index = std.mem.vecLen(&tokens)
                    let start_offset = offset
                    let start_line = line
                    let start_column = column
                    let mut token_length: u32 = 1_u32
                    i = i + 1
                    offset = offset + 1_u32
                    column = column + 1_u32
                    let mut scanning_number = true
                    while scanning_number {
                        if i < std.mem.len(source) {
                            if is_ident_continue_ascii(source[i]) {
                                i = i + 1
                                offset = offset + 1_u32
                                column = column + 1_u32
                                token_length = token_length + 1_u32
