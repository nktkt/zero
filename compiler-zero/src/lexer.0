                    }
                }
            }
            if handled {
            } else {
                if is_ident_start_ascii(source[i]) {
                    let token_index = std.mem.vecLen(&tokens)
                    let start_offset = offset
                    let start_line = line
                    let start_column = column
                    let mut token_length_u32: u32 = 1_u32
                    let start = i
                    i = i + 1
                    offset = offset + 1_u32
                    column = column + 1_u32
                    let mut scanning = true
                    while scanning {
                        if i < std.mem.len(source) {
                            if is_ident_continue_ascii(source[i]) {
                                i = i + 1
                                offset = offset + 1_u32
                                column = column + 1_u32
                                token_length_u32 = token_length_u32 + 1_u32
                            } else {
                                scanning = false
                            }
                        } else {
                            scanning = false
                        }
                    }
                    let token_len = i - start
                    let mut second: u8 = 0_u8
                    let mut third: u8 = 0_u8
                    if token_len > 1 {
                        second = source[start + 1]
                    }
                    if token_len > 2 {
                        third = source[start + 2]
                    }
                    let kind = keyword_or_identifier_kind(source[start], second, third, token_len)
                    let pushed = std.mem.vecPush(&mut tokens, kind)
                    if pushed {
                        token_offsets[token_index] = start_offset
                        token_lengths[token_index] = token_length_u32
                        token_lines[token_index] = start_line
                        token_columns[token_index] = start_column
                        handled = true
                    } else {
