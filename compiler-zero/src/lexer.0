    let mut token_columns: [24]u32 = [0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32, 0_u32]
    let mut tokens = std.mem.vec(token_storage)
    let mut i: usize = 0
    let mut offset: u32 = 0_u32
    let mut line: u32 = 1_u32
    let mut column: u32 = 1_u32
    while i < std.mem.len(source) {
        if is_space_ascii(source[i]) {
            if source[i] == 10_u8 {
                line = line + 1_u32
                column = 1_u32
            } else {
                column = column + 1_u32
            }
            i = i + 1
            offset = offset + 1_u32
        } else {
            let mut handled = false
            if source[i] == 47_u8 {
                let mut is_comment = false
                if i + 1 < std.mem.len(source) {
                    if source[i + 1] == 47_u8 {
                        is_comment = true
                    }
                }
                if is_comment {
                    i = i + 2
                    offset = offset + 2_u32
                    column = column + 2_u32
                    let mut scanning_comment = true
                    while scanning_comment {
                        if i < std.mem.len(source) {
                            if source[i] == 10_u8 {
                                scanning_comment = false
                            } else {
                                i = i + 1
                                offset = offset + 1_u32
                                column = column + 1_u32
                            }
                        } else {
                            scanning_comment = false
                        }
                    }
                } else {
                    i = i + 1
                    offset = offset + 1_u32
                    column = column + 1_u32
                }
                handled = true
            }
            if handled {
            } else {
                if source[i] == 34_u8 {
                    let token_index = std.mem.vecLen(&tokens)
                    let start_offset = offset
                    let start_line = line
                    let start_column = column
                    let mut token_length: u32 = 1_u32
                    i = i + 1
                    offset = offset + 1_u32
                    column = column + 1_u32
                    let mut scanning_string = true
                    while scanning_string {
                        if i < std.mem.len(source) {
                            if source[i] == 34_u8 {
                                i = i + 1
                                offset = offset + 1_u32
                                column = column + 1_u32
                                token_length = token_length + 1_u32
                                scanning_string = false
                            } else {
                                i = i + 1
                                offset = offset + 1_u32
                                column = column + 1_u32
                                token_length = token_length + 1_u32
                            }
                        } else {
                            scanning_string = false
                        }
                    }
                    let pushed_string = std.mem.vecPush(&mut tokens, 6_u8)
                    if pushed_string {
                        token_offsets[token_index] = start_offset
                        token_lengths[token_index] = token_length
                        token_lines[token_index] = start_line
                        token_columns[token_index] = start_column
                        handled = true
