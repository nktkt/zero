      if i + 5 < source_len {
        if std.mem.peekByte(source_ptr + i + 1) == 97_u8 {
          if std.mem.peekByte(source_ptr + i + 2) == 105_u8 {
            if std.mem.peekByte(source_ptr + i + 3) == 115_u8 {
              if std.mem.peekByte(source_ptr + i + 4) == 101_u8 {
                if std.mem.peekByte(source_ptr + i + 5) == 32_u8 {
                  raise_seen = 1_u32
                }
              }
            }
          }
        }
      }
      if i + 6 < source_len {
        if std.mem.peekByte(source_ptr + i + 1) == 101_u8 {
          if std.mem.peekByte(source_ptr + i + 2) == 115_u8 {
            if std.mem.peekByte(source_ptr + i + 3) == 99_u8 {
              if std.mem.peekByte(source_ptr + i + 4) == 117_u8 {
                if std.mem.peekByte(source_ptr + i + 5) == 101_u8 {
                  if std.mem.peekByte(source_ptr + i + 6) == 32_u8 {
                    rescue_seen = 1_u32
                  }
                }
              }
            }
          }
        }
      }
    }
    if code == 105_u8 {
      if i + 2 < source_len {
        if std.mem.peekByte(source_ptr + i + 1) == 102_u8 {
          if std.mem.peekByte(source_ptr + i + 2) == 32_u8 {
            if_seen = 1_u32
          }
        }
      }
    }
    if code == 119_u8 {
      if i + 5 < source_len {
        if std.mem.peekByte(source_ptr + i + 1) == 104_u8 {
          if std.mem.peekByte(source_ptr + i + 2) == 105_u8 {
            if std.mem.peekByte(source_ptr + i + 3) == 108_u8 {
              if std.mem.peekByte(source_ptr + i + 4) == 101_u8 {
                if std.mem.peekByte(source_ptr + i + 5) == 32_u8 {
                  while_seen = 1_u32
                }
              }
            }
          }
        }
      }
    }
    if code == 109_u8 {
      if i + 5 < source_len {
        if std.mem.peekByte(source_ptr + i + 1) == 97_u8 {
          if std.mem.peekByte(source_ptr + i + 2) == 116_u8 {
            if std.mem.peekByte(source_ptr + i + 3) == 99_u8 {
              if std.mem.peekByte(source_ptr + i + 4) == 104_u8 {
                if std.mem.peekByte(source_ptr + i + 5) == 32_u8 {
                  match_seen = 1_u32
                }
              }
            }
          }
        }
      }
    }
    if code == 99_u8 {
      if i + 5 < source_len {
        if std.mem.peekByte(source_ptr + i + 1) == 104_u8 {
          if std.mem.peekByte(source_ptr + i + 2) == 101_u8 {
            if std.mem.peekByte(source_ptr + i + 3) == 99_u8 {
              if std.mem.peekByte(source_ptr + i + 4) == 107_u8 {
