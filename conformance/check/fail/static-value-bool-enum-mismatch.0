enum Mode : u8 {
    fast,
    tiny,
}

shape Gate<static enabledFlag: Bool, static selectedMode: Mode> {
    value: i32,
}

fun readGate<static enabledFlag: Bool, static selectedMode: Mode>(gate: ref<Gate<enabledFlag,selectedMode>>) -> i32 {
    return gate.value
}

pub fun main(world: World) -> Void raises {
    let gate: Gate<true,Mode.fast> = Gate { value: 1 }
    let _value = readGate<false, Mode.fast>(&gate)
    check world.out.write("bad static bool enum mismatch\n")
}
