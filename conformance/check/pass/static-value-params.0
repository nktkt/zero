const cap: usize = 4

shape FixedVec<T, static N: usize> {
    len: usize,
    items: [N]T,
}

fun first<T, static N: usize>(vec: ref<FixedVec<T,N>>) -> T {
    return vec.items[0]
}

pub fun main(world: World) -> Void raises {
    let vec: FixedVec<u8,cap> = FixedVec { len: cap, items: [1, 2, 3, 4] }
    if first<u8, cap>(&vec) == 1 {
        check world.out.write("static value params check\n")
    }
}
