pub fun main(world: World) -> Void raises {
    let x: i32 = 7
    let y: i32 = -x
    let expect: i32 = 0 - 7
    let neg5: i32 = -5
    let expect5: i32 = 0 - 5
    let f: Bool = false
    let t: Bool = true
    if y == expect && neg5 == expect5 && !f && !t == false {
        check world.out.write("unary ops ok\n")
    }
}
