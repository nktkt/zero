shape Point {
    x: i32,
    y: i32,
}

shape Holder {
    point: Point,
}

fun read_x(point: ref<Point>) -> i32 {
    return point.x
}

fun write_x(point: mutref<Point>, value: i32) -> Void {
    point.x = value
}

pub fun main(world: World) -> Void raises {
    let mut point = Point { x: 1, y: 2 }
    let mut holder = Holder { point: Point { x: 3, y: 4 } }

    if true {
        let shared = &point
        if read_x(shared) != 1 {
            check world.out.write("borrow primitives failed\n")
            return
        }
    }

    write_x(&mut point, 5)
    write_x(&mut holder.point, 9)

    if point.x == 5 && holder.point.x == 9 {
        check world.out.write("borrow primitives ok\n")
    } else {
        check world.out.write("borrow primitives failed\n")
    }
}
