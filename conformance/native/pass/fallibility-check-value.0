fun value() -> i32 raises { BadInput } {
    return 42
}

fun run() -> i32 raises { BadInput } {
    let result = check value()
    return result
}

pub fun main(world: World) -> Void raises {
    let result = check run()
    if result == 42 {
        check world.out.write("check value ok\n")
    }
}
