fun fail_value() -> i32 raises { Missing } {
    raise Missing
}

pub fun main(world: World) -> Void raises {
    let mut small: [4]u8 = [0, 0, 0, 0]
    let a: String = std.path.join(small, "too", "long") rescue err { "fallback" }
    let b: i32 = fail_value() rescue err { 4 }
    if std.mem.eql(a, "fallback") && b == 4 {
        check world.out.write("rescue ok\n")
    }
}
