{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "target": "esnext",
    "module": "esnext"
  },
  "include": ["**/*.js", "**/*.jsx", "**/*.mjs", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
