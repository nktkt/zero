fun value(i: i32) -> i32 raises { Miss } {
    if i % 4 == 0 {
        return i
    }
    raise Miss
}

pub fun main(world: World) -> Void raises {
    let mut i = 0
    let mut total = 0
    while i < 50000 {
        let item = value(i) rescue err { 2 }
        total = total + item
        i = i + 1
    }
    if total > 0 {
        check world.out.write("rescue\n")
    }
}
